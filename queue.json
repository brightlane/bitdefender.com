import json
import random
from datetime import datetime

POSTS_FILE = "posts.json"
QUEUE_FILE = "queue.json"

def load_data():
    with open(POSTS_FILE, "r") as f:
        return json.load(f)

def load_queue():
    with open(QUEUE_FILE, "r") as f:
        return json.load(f)

def save_queue(queue):
    with open(QUEUE_FILE, "w") as f:
        json.dump(queue, f, indent=2)

def generate_post(data):
    hook = random.choice(data["hooks"])
    message = random.choice(data["messages"])
    closer = random.choice(data["closers"])
    link = data["link"]

    return f"{hook}\n\n{message}\n\n{closer}\n{link}"

def run_generator():
    data = load_data()
    queue = load_queue()

    post_text = generate_post(data)

    queue.append({
        "text": post_text,
        "status": "pending",
        "created_at": str(datetime.now())
    })

    save_queue(queue)

    print("\n[GENERATED & QUEUED POST]\n")
    print(post_text)
    print("\n------------------------\n")

if __name__ == "__main__":
    run_generator()
